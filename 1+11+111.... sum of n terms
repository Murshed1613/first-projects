#include <stdio.h>
int main()
{
    int n, i;
    long long term = 0, sum = 0;
    printf(" 1+11+111+1111+....n \nEnter number of terms:");
    scanf("%d", &n);
    for (i = 1; i <= n; i++)
    {
        term = term * 10 + 1;
        sum = sum + term;
    }
    printf("Sum of the series at %d terms = %lld\n", n, sum);
    return 0;
}
